.env

# Python runtime noise
__pycache__/
*.pyc
*.pyo

# Local logs and temp files
*.log

# Node-RED runtime state
node-red/data/.npm/
node-red/data/.config.nodes.json.backup
node-red/data/.config.runtime.json
node-red/data/.config.runtime.json.backup
node-red/data/.config.users.json
node-red/data/.config.users.json.backup
node-red/data/.flows.json.backup
node-red/data/.flows_cred.json.backup
node-red/data/.package-lock.json
node-red/data/flows_cred.json
node-red/data/node_modules/

# Grafana runtime state
grafana/data/*
!grafana/data/.gitkeep

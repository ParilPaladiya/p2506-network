# Project-wide environment variables

# PostgreSQL
POSTGRES_PASSWORD=qwerty
POSTGRES_DATABASE=sensor_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres

# Alert manager thresholds
TEMP_NORMAL_MAX=22
TEMP_WARNING_MAX=25
ANOMALY_STD_MULT=2.5
ANOMALY_REPEAT=3
WINDOW_SIZE=25

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# MQTT
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Node-RED
# Keep this stable after first boot or encrypted credentials will stop decrypting.
NODE_RED_CREDENTIAL_SECRET=replace-with-a-long-random-secret

# Data generator
DATA_INTERVAL=5
